---
import { backgroundMedia, backgroundIntervalMs } from "../data/config";
---

<div id="bg-rotator" class="bg-rotator">
  {backgroundMedia.map((item, i) => (
    item.type === "video" ? (
      <video
        class="bg-layer"
        data-index={i}
        src={item.src}
        autoplay
        muted
        loop
        playsinline
      />
    ) : (
      <img class="bg-layer" data-index={i} src={item.src} alt="" />
    )
  ))}
</div>
<div class="hit-flash"></div>

<div class="poof-cloud">
  <span class="puff"></span>
  <span class="puff"></span>
  <span class="puff"></span>
  <span class="puff"></span>
  <span class="puff"></span>
  <span class="puff"></span>
</div>

<div class="bubble-curtain">
  {Array.from({ length: 16 }).map(() => <span class="bubble"></span>)}
</div>

<div class="pipe-frame">
  <div class="pipe-body"></div>
  <div class="pipe-collar"></div>
  <div class="pipe-hole"></div>
</div>

<style>
  .bg-rotator {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: #111;
    overflow: hidden;
    perspective: 1400px;
  }

  .bg-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    z-index: 0;
    backface-visibility: hidden;
    will-change: transform, opacity;
  }

  .bg-layer.active {
    opacity: 1;
    z-index: 2;
  }

  .hit-flash {
    position: fixed;
    inset: 0;
    z-index: 3;
    background: #ff1e1e;
    opacity: 0;
    pointer-events: none;
  }

  .poof-cloud,
  .bubble-curtain,
  .pipe-frame {
    position: fixed;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    overflow: hidden;
  }

  /* Only the pipe controls visibility at the container level (fading the
     whole graphic in/out); poof and bubbles animate each child's own
     opacity individually, so their containers must stay fully opaque. */
  .pipe-frame {
    opacity: 0;
  }

  .puff {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(
      circle at 35% 35%,
      rgba(255, 255, 255, 0.95),
      rgba(225, 225, 230, 0.55) 55%,
      rgba(210, 210, 215, 0) 75%
    );
    opacity: 0;
    filter: blur(1px);
  }

  .bubble {
    position: absolute;
    bottom: -20%;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.55);
    background: radial-gradient(
      circle at 30% 26%,
      rgba(255, 255, 255, 0.98) 0%,
      rgba(255, 255, 255, 0.8) 10%,
      rgba(195, 228, 255, 0.45) 42%,
      rgba(130, 185, 240, 0.2) 72%,
      rgba(130, 185, 240, 0) 100%
    );
    box-shadow:
      inset -3px -3px 8px rgba(255, 255, 255, 0.4),
      inset 3px 3px 6px rgba(70, 130, 200, 0.35),
      0 0 4px rgba(255, 255, 255, 0.25);
    opacity: 0;
  }

  .pipe-body {
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: 30%;
    height: 22%;
    background: linear-gradient(90deg, #146614 0%, #2f9e2f 14%, #74da74 45%, #2f9e2f 80%, #146614 100%);
    border: 4px solid #0a3d0a;
    border-bottom: none;
  }

  .pipe-collar {
    position: absolute;
    left: 50%;
    bottom: 17%;
    transform: translateX(-50%);
    width: 42%;
    height: 9%;
    background: linear-gradient(90deg, #146614 0%, #2f9e2f 14%, #74da74 45%, #2f9e2f 80%, #146614 100%);
    border: 4px solid #0a3d0a;
    border-radius: 14px;
  }

  .pipe-hole {
    position: absolute;
    left: 50%;
    bottom: 19.5%;
    transform: translateX(-50%);
    width: 30%;
    height: 5%;
    background: #08260c;
    border-radius: 50%;
  }
</style>

<script is:inline define:vars={{ intervalMs: backgroundIntervalMs }}>
  const layers = Array.from(document.querySelectorAll(".bg-layer"));
  const flash = document.querySelector(".hit-flash");
  const poofCloud = document.querySelector(".poof-cloud");
  const bubbleCurtain = document.querySelector(".bubble-curtain");
  const pipeFrame = document.querySelector(".pipe-frame");
  const ambientLayers = Array.from(document.querySelectorAll(".ambient-layer"));
  let ambientCurrent = 0;

  function updateAmbient(src) {
    if (ambientLayers.length < 2) return;
    const nextIdx = 1 - ambientCurrent;
    ambientLayers[nextIdx].style.backgroundImage = `url("${src}")`;
    ambientLayers[nextIdx].classList.add("active");
    ambientLayers[ambientCurrent].classList.remove("active");
    ambientCurrent = nextIdx;
  }

  for (let i = layers.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [layers[i], layers[j]] = [layers[j], layers[i]];
  }

  let current = 0;
  let isAnimating = false;
  let timerId = null;

  function playVideo(el) {
    if (el.tagName === "VIDEO") {
      el.currentTime = 0;
      el.play().catch(() => {});
    }
  }

  function pauseVideo(el) {
    if (el.tagName === "VIDEO") {
      el.pause();
    }
  }

  function resetLayer(el) {
    el.style.transition = "none";
    el.style.opacity = "0";
    el.style.transform = "none";
    el.style.zIndex = "0";
    el.classList.remove("active");
  }

  function promote(el) {
    el.style.opacity = "1";
    el.style.transform = "none";
    el.style.zIndex = "2";
    el.classList.add("active");
    if (el.tagName === "IMG") {
      updateAmbient(el.currentSrc || el.src);
    }
  }

  function crossfade(curEl, nextEl, duration) {
    nextEl.style.zIndex = "1";
    curEl.style.zIndex = "2";
    nextEl.animate([{ opacity: 0 }, { opacity: 1 }], { duration, easing: "ease", fill: "forwards" });
    return curEl.animate([{ opacity: 1 }, { opacity: 0 }], { duration, easing: "ease", fill: "forwards" }).finished;
  }

  function swipe(curEl, nextEl, duration) {
    const dir = Math.random() < 0.5 ? 1 : -1;
    nextEl.style.zIndex = "1";
    nextEl.style.opacity = "1";
    curEl.style.zIndex = "2";
    nextEl.animate(
      [{ transform: `translateX(${dir * 100}%)` }, { transform: "translateX(0)" }],
      { duration, easing: "cubic-bezier(.4,0,.2,1)", fill: "forwards" }
    );
    return curEl.animate(
      [{ transform: "translateX(0)" }, { transform: `translateX(${dir * -100}%)` }],
      { duration, easing: "cubic-bezier(.4,0,.2,1)", fill: "forwards" }
    ).finished;
  }

  function hit(curEl, nextEl, duration) {
    nextEl.style.zIndex = "1";
    nextEl.style.opacity = "1";
    nextEl.style.transform = "none";
    curEl.style.zIndex = "2";
    curEl.style.transformOrigin = "center center";

    const dir = Math.random() < 0.5 ? 1 : -1;

    flash.animate([{ opacity: 0 }, { opacity: 0.75 }, { opacity: 0 }], {
      duration: duration * 0.4,
      easing: "ease-out",
    });

    return curEl.animate(
      [
        { transform: "translateY(0) rotate(0deg) scale(1)", offset: 0 },
        { transform: `translateY(-2%) rotate(${dir * 2}deg) scale(1.02)`, offset: 0.15 },
        { transform: `translateY(10%) rotate(${dir * 12}deg) scale(0.98)`, offset: 0.55 },
        { transform: `translateY(-4%) rotate(${dir * 9}deg) scale(0.97)`, offset: 0.75 },
        { transform: `translateY(130%) rotate(${dir * 20}deg) scale(0.9)`, offset: 1 },
      ],
      { duration, easing: "ease-in", fill: "forwards" }
    ).finished;
  }

  function spin(curEl, nextEl, duration) {
    nextEl.style.zIndex = "1";
    nextEl.style.opacity = "1";
    nextEl.style.transform = "none";
    curEl.style.zIndex = "2";
    curEl.style.transformOrigin = "center center";

    const dir = Math.random() < 0.5 ? 1 : -1;

    return curEl.animate(
      [
        { transform: "translate(0, 0) rotate(0deg) scale(1)", opacity: 1, offset: 0 },
        { transform: "translate(0, 0) rotate(0deg) scale(1.08)", opacity: 1, offset: 0.12 },
        { transform: `translate(${dir * 25}%, 15%) rotate(${dir * 360}deg) scale(0.55)`, opacity: 1, offset: 0.5 },
        { transform: `translate(${dir * 65}%, 85%) rotate(${dir * 720}deg) scale(0.1)`, opacity: 1, offset: 0.85 },
        { transform: `translate(${dir * 80}%, 110%) rotate(${dir * 820}deg) scale(0.02)`, opacity: 0, offset: 1 },
      ],
      { duration, easing: "cubic-bezier(.55,0,.85,.35)", fill: "forwards" }
    ).finished;
  }

  function flip(curEl, nextEl, duration) {
    nextEl.style.zIndex = "1";
    nextEl.style.opacity = "1";
    nextEl.style.transform = "none";
    curEl.style.zIndex = "2";
    curEl.style.transformOrigin = "center center";

    return curEl.animate(
      [
        { transform: "rotateY(0deg)", opacity: 1, offset: 0 },
        { transform: "rotateY(-90deg)", opacity: 1, offset: 0.5 },
        { transform: "rotateY(-90deg)", opacity: 0, offset: 0.501 },
        { transform: "rotateY(-90deg)", opacity: 0, offset: 1 },
      ],
      { duration, easing: "ease-in", fill: "forwards" }
    ).finished;
  }

  function poof(curEl, nextEl, duration) {
    nextEl.style.zIndex = "1";
    nextEl.style.opacity = "1";
    nextEl.style.transform = "none";
    curEl.style.zIndex = "2";
    curEl.style.transformOrigin = "center center";

    const puffOffsets = [
      { x: -22, y: -8 },
      { x: 20, y: -14 },
      { x: -10, y: 12 },
      { x: 12, y: 16 },
      { x: -24, y: 4 },
      { x: 24, y: -2 },
    ];

    Array.from(poofCloud.querySelectorAll(".puff")).forEach((puff, i) => {
      const { x, y } = puffOffsets[i % puffOffsets.length];
      const size = 26 + Math.random() * 18;
      puff.style.width = `${size}%`;
      puff.style.height = `${size}%`;
      puff.style.left = `${50 - size / 2}%`;
      puff.style.top = `${50 - size / 2}%`;
      puff.animate(
        [
          { transform: "translate(0, 0) scale(0.25)", opacity: 0, offset: 0 },
          { transform: `translate(${x * 0.4}%, ${y * 0.4}%) scale(0.9)`, opacity: 0.9, offset: 0.5 },
          { transform: `translate(${x}%, ${y}%) scale(1.5)`, opacity: 0, offset: 1 },
        ],
        { duration: duration * 0.85, delay: duration * 0.25 + i * 25, easing: "ease-out" }
      );
    });

    return curEl.animate(
      [
        { transform: "translate(0, 0) rotate(0deg) scale(1)", offset: 0 },
        { transform: "translate(-1.5%, 0) rotate(-4deg) scale(1)", offset: 0.12 },
        { transform: "translate(1.5%, 0) rotate(4deg) scale(1)", offset: 0.24 },
        { transform: "translate(-1%, 0) rotate(-3deg) scale(1)", offset: 0.36 },
        { transform: "translate(0, 0) rotate(0deg) scale(0.94)", offset: 0.48 },
        { transform: "translate(0, -4%) rotate(0deg) scale(0.4)", opacity: 1, offset: 0.72 },
        { transform: "translate(0, -6%) rotate(0deg) scale(0.1)", opacity: 0, offset: 1 },
      ],
      { duration, easing: "ease-in", fill: "forwards" }
    ).finished;
  }

  function bubbles(curEl, nextEl, duration) {
    nextEl.style.zIndex = "1";
    nextEl.style.opacity = "1";
    nextEl.style.transform = "none";
    curEl.style.zIndex = "2";
    curEl.style.opacity = "1";
    curEl.style.transform = "none";

    const bubbleEls = Array.from(bubbleCurtain.querySelectorAll(".bubble"));
    const n = bubbleEls.length;
    const slot = 100 / n;

    const riseAnimations = bubbleEls.map((b, i) => {
      const size = 14 + Math.random() * 12; // smaller + tighter range so each bubble stays distinct
      const left = Math.max(0, Math.min(100 - size, i * slot + (Math.random() * slot * 0.5 - slot * 0.25)));
      const maxDelay = duration * 0.22;
      const delay = Math.random() * maxDelay;
      const riseDuration = duration - delay; // every bubble finishes by `duration`, none cut off mid-rise
      const wobble = Math.random() * 8 - 4;

      // `transform: translate(%)` is relative to the bubble's OWN size, not
      // the viewport — a tiny bubble needs a much bigger % value than a big
      // one to cover the same physical distance. Compute the travel in
      // own-size units so every bubble actually clears the top of the
      // screen, regardless of size (this was the "stuck 3/4 up" bug).
      const travel = ((120 + size) / size) * 100;

      b.style.width = `${size}%`;
      b.style.height = `${size}%`;
      b.style.left = `${left}%`;

      return b.animate(
        [
          { transform: "translate(0, 0)", opacity: 0, offset: 0 },
          { transform: `translate(${wobble * 0.5}%, ${-travel * 0.35}%)`, opacity: 0.95, offset: 0.35 },
          { transform: `translate(${-wobble}%, ${-travel * 0.7}%)`, opacity: 0.9, offset: 0.7 },
          { transform: `translate(${wobble * 0.6}%, ${-travel}%)`, opacity: 0, offset: 1 },
        ],
        { duration: riseDuration, delay, easing: "ease-in-out" }
      ).finished;
    });

    const revealAt = duration * 0.45;
    const revealPromise = new Promise((resolve) => {
      setTimeout(() => {
        curEl.style.transition = "none";
        curEl.style.opacity = "0";
        resolve();
      }, revealAt);
    });

    return Promise.all([revealPromise, ...riseAnimations]);
  }

  function pipe(curEl, nextEl, duration) {
    nextEl.style.zIndex = "1";
    nextEl.style.opacity = "1";
    nextEl.style.transform = "none";
    curEl.style.zIndex = "2";
    curEl.style.transformOrigin = "50% 75%";

    pipeFrame.animate(
      [
        { opacity: 0, offset: 0 },
        { opacity: 1, offset: 0.14 },
        { opacity: 1, offset: 0.9 },
        { opacity: 0, offset: 1 },
      ],
      { duration, easing: "ease" }
    );

    // Every clip-path keyframe keeps 4 polygon points (even when two of
    // them coincide) so the browser can interpolate smoothly between them
    // instead of jump-cutting. Bottom corners pull in first — a paper-fold/
    // funnel taper — before the top follows, while translateY/scale carry
    // the whole thing down and in toward the pipe opening.
    return curEl.animate(
      [
        {
          transform: "translateY(0) scale(1)",
          clipPath: "polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)",
          offset: 0,
        },
        {
          transform: "translateY(-6%) scale(0.92)",
          clipPath: "polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)",
          offset: 0.22,
        },
        {
          transform: "translateY(-3%) scale(0.88)",
          clipPath: "polygon(0% 0%, 100% 0%, 78% 100%, 22% 100%)",
          offset: 0.42,
        },
        {
          transform: "translateY(18%) scale(0.55)",
          clipPath: "polygon(15% 0%, 85% 0%, 50% 100%, 50% 100%)",
          offset: 0.72,
        },
        {
          transform: "translateY(42%) scale(0.15)",
          clipPath: "polygon(35% 0%, 65% 0%, 50% 100%, 50% 100%)",
          opacity: 0,
          offset: 1,
        },
      ],
      { duration, easing: "cubic-bezier(.6,0,.85,.35)", fill: "forwards" }
    ).finished;
  }

  const effects = [
    { run: crossfade, duration: 1100 },
    { run: swipe, duration: 700 },
    { run: hit, duration: 900 },
    { run: flip, duration: 800 },
    { run: spin, duration: 850 },
    { run: pipe, duration: 1050 },
    { run: bubbles, duration: 1400 },
    // poof is implemented below but temporarily left out of rotation while
    // we confirm bubbles looks right on its own.
    // { run: poof, duration: 950 },
  ];

  // Shuffle-bag picker (Spotify-style): play through a shuffled bag of all
  // effects before reshuffling, and never repeat the same effect back-to-back.
  let bag = [];
  let lastEffectIndex = -1;

  function refillBag() {
    bag = effects.map((_, i) => i);
    for (let i = bag.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [bag[i], bag[j]] = [bag[j], bag[i]];
    }
    if (bag[0] === lastEffectIndex && bag.length > 1) {
      const swapWith = 1 + Math.floor(Math.random() * (bag.length - 1));
      [bag[0], bag[swapWith]] = [bag[swapWith], bag[0]];
    }
  }

  function nextEffect() {
    if (bag.length === 0) refillBag();
    const idx = bag.pop();
    lastEffectIndex = idx;
    return effects[idx];
  }

  function scheduleAuto() {
    clearTimeout(timerId);
    if (layers.length > 1) {
      timerId = setTimeout(() => advance(), intervalMs);
    }
  }

  function advance() {
    if (isAnimating || layers.length < 2) return;
    isAnimating = true;

    const next = (current + 1) % layers.length;
    const curEl = layers[current];
    const nextEl = layers[next];
    const effect = nextEffect();

    playVideo(nextEl);

    effect.run(curEl, nextEl, effect.duration).then(() => {
      resetLayer(curEl);
      pauseVideo(curEl);
      promote(nextEl);
      curEl.style.transformOrigin = "";
      current = next;
      isAnimating = false;
    });

    scheduleAuto();
  }

  if (layers.length > 0) {
    promote(layers[0]);
    playVideo(layers[0]);
    scheduleAuto();

    document.addEventListener("click", (e) => {
      if (e.target.closest("a, button")) return;
      advance();
    });
  }
</script>
