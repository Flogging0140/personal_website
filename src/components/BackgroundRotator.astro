---
import { backgroundMedia, backgroundIntervalMs } from "../data/config";
---

<div id="bg-rotator" class="bg-rotator">
  {backgroundMedia.map((item, i) => (
    item.type === "video" ? (
      <video
        class="bg-layer"
        data-index={i}
        src={item.src}
        autoplay
        muted
        loop
        playsinline
      />
    ) : (
      <img class="bg-layer" data-index={i} src={item.src} alt="" />
    )
  ))}
</div>
<div class="hit-flash"></div>

<style>
  .bg-rotator {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: #111;
    overflow: hidden;
    perspective: 1400px;
  }

  .bg-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    z-index: 0;
    backface-visibility: hidden;
    will-change: transform, opacity;
  }

  .bg-layer.active {
    opacity: 1;
    z-index: 2;
  }

  .hit-flash {
    position: fixed;
    inset: 0;
    z-index: 3;
    background: #ff1e1e;
    opacity: 0;
    pointer-events: none;
  }
</style>

<script is:inline define:vars={{ intervalMs: backgroundIntervalMs }}>
  const layers = Array.from(document.querySelectorAll(".bg-layer"));
  const flash = document.querySelector(".hit-flash");
  const ambientLayers = Array.from(document.querySelectorAll(".ambient-layer"));
  let ambientCurrent = 0;

  function updateAmbient(src) {
    if (ambientLayers.length < 2) return;
    const nextIdx = 1 - ambientCurrent;
    ambientLayers[nextIdx].style.backgroundImage = `url("${src}")`;
    ambientLayers[nextIdx].classList.add("active");
    ambientLayers[ambientCurrent].classList.remove("active");
    ambientCurrent = nextIdx;
  }

  for (let i = layers.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [layers[i], layers[j]] = [layers[j], layers[i]];
  }

  let current = 0;
  let isAnimating = false;
  let timerId = null;

  function playVideo(el) {
    if (el.tagName === "VIDEO") {
      el.currentTime = 0;
      el.play().catch(() => {});
    }
  }

  function pauseVideo(el) {
    if (el.tagName === "VIDEO") {
      el.pause();
    }
  }

  function resetLayer(el) {
    el.style.transition = "none";
    el.style.opacity = "0";
    el.style.transform = "none";
    el.style.zIndex = "0";
    el.classList.remove("active");
  }

  function promote(el) {
    el.style.opacity = "1";
    el.style.transform = "none";
    el.style.zIndex = "2";
    el.classList.add("active");
    if (el.tagName === "IMG") {
      updateAmbient(el.currentSrc || el.src);
    }
  }

  function crossfade(curEl, nextEl, duration) {
    nextEl.style.zIndex = "1";
    curEl.style.zIndex = "2";
    nextEl.animate([{ opacity: 0 }, { opacity: 1 }], { duration, easing: "ease", fill: "forwards" });
    return curEl.animate([{ opacity: 1 }, { opacity: 0 }], { duration, easing: "ease", fill: "forwards" }).finished;
  }

  function swipe(curEl, nextEl, duration) {
    const dir = Math.random() < 0.5 ? 1 : -1;
    nextEl.style.zIndex = "1";
    nextEl.style.opacity = "1";
    curEl.style.zIndex = "2";
    nextEl.animate(
      [{ transform: `translateX(${dir * 100}%)` }, { transform: "translateX(0)" }],
      { duration, easing: "cubic-bezier(.4,0,.2,1)", fill: "forwards" }
    );
    return curEl.animate(
      [{ transform: "translateX(0)" }, { transform: `translateX(${dir * -100}%)` }],
      { duration, easing: "cubic-bezier(.4,0,.2,1)", fill: "forwards" }
    ).finished;
  }

  function hit(curEl, nextEl, duration) {
    nextEl.style.zIndex = "1";
    nextEl.style.opacity = "1";
    nextEl.style.transform = "none";
    curEl.style.zIndex = "2";
    curEl.style.transformOrigin = "center center";

    const dir = Math.random() < 0.5 ? 1 : -1;

    flash.animate([{ opacity: 0 }, { opacity: 0.75 }, { opacity: 0 }], {
      duration: duration * 0.4,
      easing: "ease-out",
    });

    return curEl.animate(
      [
        { transform: "translateY(0) rotate(0deg) scale(1)", offset: 0 },
        { transform: `translateY(-2%) rotate(${dir * 2}deg) scale(1.02)`, offset: 0.15 },
        { transform: `translateY(10%) rotate(${dir * 12}deg) scale(0.98)`, offset: 0.55 },
        { transform: `translateY(-4%) rotate(${dir * 9}deg) scale(0.97)`, offset: 0.75 },
        { transform: `translateY(130%) rotate(${dir * 20}deg) scale(0.9)`, offset: 1 },
      ],
      { duration, easing: "ease-in", fill: "forwards" }
    ).finished;
  }

  function spin(curEl, nextEl, duration) {
    nextEl.style.zIndex = "1";
    nextEl.style.opacity = "1";
    nextEl.style.transform = "none";
    curEl.style.zIndex = "2";
    curEl.style.transformOrigin = "center center";

    const dir = Math.random() < 0.5 ? 1 : -1;

    return curEl.animate(
      [
        { transform: "translate(0, 0) rotate(0deg) scale(1)", opacity: 1, offset: 0 },
        { transform: "translate(0, 0) rotate(0deg) scale(1.08)", opacity: 1, offset: 0.12 },
        { transform: `translate(${dir * 25}%, 15%) rotate(${dir * 360}deg) scale(0.55)`, opacity: 1, offset: 0.5 },
        { transform: `translate(${dir * 65}%, 85%) rotate(${dir * 720}deg) scale(0.1)`, opacity: 1, offset: 0.85 },
        { transform: `translate(${dir * 80}%, 110%) rotate(${dir * 820}deg) scale(0.02)`, opacity: 0, offset: 1 },
      ],
      { duration, easing: "cubic-bezier(.55,0,.85,.35)", fill: "forwards" }
    ).finished;
  }

  function flip(curEl, nextEl, duration) {
    nextEl.style.zIndex = "1";
    nextEl.style.opacity = "1";
    nextEl.style.transform = "none";
    curEl.style.zIndex = "2";
    curEl.style.transformOrigin = "center center";

    return curEl.animate(
      [
        { transform: "rotateY(0deg)", opacity: 1, offset: 0 },
        { transform: "rotateY(-90deg)", opacity: 1, offset: 0.5 },
        { transform: "rotateY(-90deg)", opacity: 0, offset: 0.501 },
        { transform: "rotateY(-90deg)", opacity: 0, offset: 1 },
      ],
      { duration, easing: "ease-in", fill: "forwards" }
    ).finished;
  }

  const effects = [
    { run: crossfade, duration: 1100 },
    { run: swipe, duration: 700 },
    { run: hit, duration: 900 },
    { run: flip, duration: 800 },
    { run: spin, duration: 850 },
  ];

  // Shuffle-bag picker (Spotify-style): play through a shuffled bag of all
  // effects before reshuffling, and never repeat the same effect back-to-back.
  let bag = [];
  let lastEffectIndex = -1;

  function refillBag() {
    bag = effects.map((_, i) => i);
    for (let i = bag.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [bag[i], bag[j]] = [bag[j], bag[i]];
    }
    if (bag[0] === lastEffectIndex && bag.length > 1) {
      const swapWith = 1 + Math.floor(Math.random() * (bag.length - 1));
      [bag[0], bag[swapWith]] = [bag[swapWith], bag[0]];
    }
  }

  function nextEffect() {
    if (bag.length === 0) refillBag();
    const idx = bag.pop();
    lastEffectIndex = idx;
    return effects[idx];
  }

  function scheduleAuto() {
    clearTimeout(timerId);
    if (layers.length > 1) {
      timerId = setTimeout(() => advance(), intervalMs);
    }
  }

  function advance() {
    if (isAnimating || layers.length < 2) return;
    isAnimating = true;

    const next = (current + 1) % layers.length;
    const curEl = layers[current];
    const nextEl = layers[next];
    const effect = nextEffect();

    playVideo(nextEl);

    effect.run(curEl, nextEl, effect.duration).then(() => {
      resetLayer(curEl);
      pauseVideo(curEl);
      promote(nextEl);
      curEl.style.transformOrigin = "";
      current = next;
      isAnimating = false;
    });

    scheduleAuto();
  }

  if (layers.length > 0) {
    promote(layers[0]);
    playVideo(layers[0]);
    scheduleAuto();

    document.addEventListener("click", (e) => {
      if (e.target.closest("a, button")) return;
      advance();
    });
  }
</script>
