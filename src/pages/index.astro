---
import BackgroundRotator from "../components/BackgroundRotator.astro";
import SocialIcons from "../components/SocialIcons.astro";
import { profile, links } from "../data/config";
import "../styles/global.css";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{profile.name}</title>
		<meta name="description" content={profile.tagline} />
	</head>
	<body>
		<div class="ambient-backdrop">
			<div class="ambient-layer"></div>
			<div class="ambient-layer"></div>
		</div>
		<div class="phone-frame">
			<BackgroundRotator />
			<div class="scrim"></div>

			<main class="page">
				<img class="avatar" src={profile.avatar} alt={profile.name} />
				<h1 class="name">{profile.name}</h1>
				<p class="tagline">{profile.tagline}</p>

				{links.length > 0 && (
					<nav class="links">
						{links.map((link) => (
							<a
								class={`link-btn ${link.emphasis ? "emphasis" : ""}`}
								href={link.href}
								target="_blank"
								rel="noopener noreferrer"
							>
								<span class="link-label">{link.label}</span>
								{link.sublabel && <span class="link-sublabel">{link.sublabel}</span>}
							</a>
						))}
					</nav>
				)}

				<SocialIcons />
			</main>
		</div>
	</body>
</html>
